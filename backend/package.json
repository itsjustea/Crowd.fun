{
  "name": "crowdfund-indexer",
  "version": "1.0.0",
  "description": "Blockchain indexer and API for Crowd.Fun",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "dev:ws": "nodemon src/indexer/index-ws.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:ws\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "index": "ts-node src/indexer/index.ts",
    "index:watch": "nodemon src/indexer/index.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "pinata": "^2.5.5",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.2",
    "prisma": "^5.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
